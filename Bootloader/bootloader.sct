; *************************************************************
; *** Bootloader Scatter-Loading Description File ***
; *************************************************************

LR_IROM1 0x08000000 0x00004000  {    ; 16KB Bootloader
  ER_IROM1 0x08000000 0x00004000  {
    *.o (RESET, +First)
    *(InRoot$$Sections)
    .ANY (+RO)
  }
  RW_IRAM1 0x20000000 0x00030000  {  ; 192KB SRAM
    .ANY (+RW +ZI)
  }
}

